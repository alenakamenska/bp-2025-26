{
  "rewrites": [
    {
      "source": "/produkt/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebook|facebot|whatsapp|twitter|linkedin|telegram|discord).*"
        }
      ],
      "destination": "/api/bot-meta"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}